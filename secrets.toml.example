# Copy this file to .streamlit/secrets.toml for LOCAL development and fill in your real key.
# Never commit the real secrets.toml to GitHub — it's already in .gitignore.
#
# On Streamlit Community Cloud, you don't upload this file at all — instead paste the
# same content into your app's Settings -> Secrets box in the dashboard.

OPENROUTER_API_KEY = "sk-or-v1-your-real-key-here"
